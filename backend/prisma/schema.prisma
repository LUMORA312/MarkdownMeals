generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  coverImage  String
  redirectUrl String
  rating      Float?
  createdAt   DateTime @default(now())

  categories RestaurantCategory[]
  dishes     Dish[]
  tokens     RedirectToken[]
  ratings    Rating[]
  favorites  Favorite[]
}

model RestaurantCategory {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  restaurantId String     @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Dish {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  image         String
  category      String
  primaryTaste  String
  price         Float?
  originalPrice Float?
  dealType      String?
  dealExpiresAt DateTime?
  restaurantId  String    @db.ObjectId
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  modifiers   DishModifier[]
  tokenDishes TokenDish[]

  @@index([restaurantId])
}

model DishModifier {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  dishId String @db.ObjectId
  dish   Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@index([dishId])
}

model RedirectToken {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  restaurantId       String   @db.ObjectId
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  ratingAvailableAt  DateTime

  dishes TokenDish[]
  rating Rating?

  @@index([restaurantId])
}

model TokenDish {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  tokenId String @db.ObjectId
  dishId  String @db.ObjectId
  token   RedirectToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  dish    Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([tokenId, dishId])
  @@index([tokenId])
  @@index([dishId])
}

model Rating {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  emoji     String
  tokenId   String   @unique @db.ObjectId
  token     RedirectToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  restaurantId String @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  tags RatingTag[]

  @@index([restaurantId])
}

model RatingTag {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  ratingId String @db.ObjectId
  rating   Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@index([ratingId])
}

model Favorite {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  sessionId    String
  restaurantId String     @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([sessionId, restaurantId])
  @@index([sessionId])
  @@index([restaurantId])
}
